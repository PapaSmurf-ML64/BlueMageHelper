<Project Sdk="Dalamud.NET.Sdk/14.0.1">
	<PropertyGroup>
        <Name>Blue Mage Helper</Name>
        <Author>Infi, Sl0nderman, harbingerftw</Author>
        <Version>3.1.0.0</Version>
        <Punchline>Helps you fill out your Blue Mage Spellbook</Punchline>
        <Description>Adds monster names and coordinates to the "Where to Learn" section of your blue mage spellbook.</Description>
        <Tags>spells;spellbook;blu</Tags>
        <CategoryTags>jobs</CategoryTags>
        <RepoUrl>https://github.com/harbingerftw/BlueMageHelper</RepoUrl>
        <ApplicableVersion>any</ApplicableVersion>
	</PropertyGroup>

    <PropertyGroup>
        <DalamudLibPath>$(appdata)\XIVLauncher\addon\Hooks\dev\</DalamudLibPath>
    </PropertyGroup>

	<ItemGroup>
		<Content Include="images\icon.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Content Include="spells.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>
</Project>
